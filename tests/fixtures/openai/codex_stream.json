          },
          {
            "data": "data: {\"type\":\"response.done\",\"response\":{\"id\":\"response\",\"status\":\"completed\",\"output\":[{\"type\":\"message\",\"id\":\"msg\",\"role\":\"assistant\",\"status\":\"completed\",\"content\":[{\"type\":\"output_text\",\"text\":\"Codex works\",\"annotations\":[]}] }]}}\n\n"
